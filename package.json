{
	"name": "cl-plugin-site-blocks",
	"version": "1.1.0",
	"description": "Blocks for the Choctaw Landing site.",
	"prettier": "@wordpress/prettier-config",
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"engines": {
		"node": ">= 24"
	},
	"author": "Choctaw Nation of Oklahoma",
	"files": [
		"build",
		"inc",
		"README.md",
		"LICENSE",
		"CHANGELOG.md",
		"cl-plugin-site-blocks.php",
		"vendor"
	],
	"scripts": {
		"build": "wp-scripts build  --blocks-manifest --webpack-copy-php --output-path=build --config=webpack.config.mjs --experimental-modules",
		"lint:css": "npx stylelint '**/*.scss' '**/*.css' --fix --allow-empty-input",
		"lint:js": "npx eslint --fix",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "npm run build && wp-scripts plugin-zip",
		"start": "wp-scripts start --webpack-copy-php --blocks-manifest --experimental-modules --config=webpack.config.mjs"
	},
	"devDependencies": {
		"@eslint/compat": "^2",
		"@wordpress/block-editor": "^15.19.0",
		"@wordpress/blocks": "^15.19.0",
		"@wordpress/components": "^33.1.0",
		"@wordpress/core-data": "^7.46.0",
		"@wordpress/data": "^10.46.0",
		"@wordpress/date": "^5.46.0",
		"@wordpress/dom-ready": "^4.46.0",
		"@wordpress/editor": "^14.46.0",
		"@wordpress/element": "^6.46.0",
		"@wordpress/eslint-plugin": "^25",
		"@wordpress/icons": "^13.1.0",
		"@wordpress/interactivity": "^6.46.0",
		"@wordpress/scripts": "^32",
		"eslint": "^9",
		"globals": "^17",
		"prettier": "npm:wp-prettier@^3",
		"stylelint": "^17",
		"stylelint-config-standard-scss": "^17",
		"stylelint-scss": "^7",
		"typescript": "^6"
	}
}
