{
	"name": "cl-plugin-site-blocks",
	"version": "1.0.0",
	"description": "Blocks for the Choctaw Landing site.",
	"prettier": "@wordpress/prettier-config",
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"engines": {
		"node": ">= 24"
	},
	"author": "Choctaw Nation of Oklahoma",
	"files": [
		"build",
		"inc",
		"README.md",
		"LICENSE",
		"CHANGELOG.md",
		"cl-plugin-site-blocks.php",
		"vendor"
	],
	"scripts": {
		"build": "wp-scripts build  --blocks-manifest --webpack-copy-php --output-path=build",
		"build:modules": "wp-scripts build src/interactive-blocks --webpack-copy-php --blocks-manifest --experimental-modules --output-path=build/interactive-blocks",
		"lint:css": "npx stylelint '**/*.scss' '**/*.css' --fix --allow-empty-input",
		"lint:js": "npx eslint --fix",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts build && wp-scripts plugin-zip",
		"start": "wp-scripts start --blocks-manifest --webpack-copy-php --output-path=build",
		"start:modules": "wp-scripts start src/interactive-blocks --webpack-copy-php --blocks-manifest --experimental-modules --output-path=build/interactive-blocks"
	},
	"devDependencies": {
		"@eslint/compat": "^2",
		"@wordpress/block-editor": "^15.19.0",
		"@wordpress/blocks": "^15.19.0",
		"@wordpress/components": "^33.1.0",
		"@wordpress/eslint-plugin": "^25",
		"@wordpress/icons": "^13.1.0",
		"@wordpress/interactivity": "^6.46.0",
		"@wordpress/scripts": "^32",
		"eslint": "^9",
		"globals": "^17",
		"prettier": "npm:wp-prettier@^3",
		"stylelint": "^17",
		"stylelint-config-standard-scss": "^17",
		"stylelint-scss": "^7",
		"typescript": "^6"
	}
}
