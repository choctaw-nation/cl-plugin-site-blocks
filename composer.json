{
	"name": "choctaw-nation/cl-plugin-site-blocks",
	"description": "Blocks for the Choctaw Landing site.",
	"type": "project",
	"version": "1.1.0",
	"autoload": {
		"classmap": [
			"inc/"
		]
	},
	"extra": {
		"installer-paths": {
			"vendor/{$name}/": [
				"wpengine/advanced-custom-fields"
			]
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"repositories": [
		{
			"type": "composer",
			"url": "https://composer.advancedcustomfields.com"
		}
	],
	"scripts": {
		"phpcs": "phpcs inc/ src/ cl-plugin-site-blocks.php --extensions=php",
		"phpcbf": "phpcbf inc/ src/ cl-plugin-site-blocks.php --extensions=php",
		"test": "phpunit",
		"install-tests": [
			"chmod +x bin/local-mysql-socket.sh",
			"bash -lc 'SOCK=\"$(bin/local-mysql-socket.sh)\"; bash -x bin/install-wp-tests.sh wordpress_test root root \"$SOCK\" latest'"
		]
	},
	"require-dev": {
		"doctrine/instantiator": "^1",
		"phpunit/phpunit": "^9",
		"wp-coding-standards/wpcs": "*",
		"wpengine/advanced-custom-fields": "*",
		"yoast/phpunit-polyfills": "^4.0",
		"php-stubs/acf-pro-stubs": "*"
	}
}
